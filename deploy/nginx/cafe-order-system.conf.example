# Example reverse proxy configuration for Cafe Order System.
# Replace example.com and certificate paths before using.
#
# Production serves frontend/dist as static files. Do not expose the Vite dev
# server. /api/ is proxied to Nyan8, which calls NyanQL internally.

server {
    listen 80;
    server_name example.com;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name example.com;

    ssl_certificate /etc/letsencrypt/live/example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/example.com/privkey.pem;

    root /opt/cafe-order-system/frontend/dist;
    index index.html;

    access_log /var/log/nginx/cafe-order-system.access.log;
    error_log /var/log/nginx/cafe-order-system.error.log;

    # If image upload or larger imports are added later, set an explicit limit.
    # client_max_body_size 10m;

    location / {
        try_files $uri /index.html;
    }

    location /api/ {
        # Nyan8 api.json keys are "api/..." paths. The trailing slash keeps
        # /api/foo forwarded as /api/foo.
        proxy_pass http://127.0.0.1:8889/api/;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;

        # Auth policy:
        # - The target design is cafe_session with Secure, HttpOnly, SameSite=Lax.
        # - Current Nyan8 behavior must be verified in the production runtime for
        #   real Set-Cookie and Cookie header propagation.
        # - If Cookie is not passed through to JavaScript params, add a verified
        #   proxy/runtime bridge such as cookie-to-Authorization conversion.
        # - Do not enable an unverified header transformation as production policy.
    }
}
