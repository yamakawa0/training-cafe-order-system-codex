# Copy this file to .env.production on the production host and edit values.
# Do not commit real production secrets.
DATABASE_URL=postgres://cafe_app:change-me@db.example.internal:5432/cafe_order_system
NYANQL_HOST=127.0.0.1
NYANQL_PORT=8890
NYAN8_HOST=127.0.0.1
NYAN8_PORT=8889
APP_BASE_URL=https://example.com
SESSION_COOKIE_NAME=cafe_session
SESSION_TTL_SECONDS=28800
COOKIE_SECURE=true
COOKIE_SAMESITE=Lax
LOG_DIR=/opt/cafe-order-system/logs
NYANQL_BASIC_AUTH_USER=nyanql
NYANQL_BASIC_AUTH_PASSWORD=change-this-secret
NYANQL_BASE_URL=http://127.0.0.1:8890
